<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Class="CalculatorApp.MainPage"
             BackgroundColor="Black">

    <VerticalStackLayout Padding="10" Spacing="10">

        <!-- Display -->
        <Entry x:Name="Display"
               Text="0"
               FontSize="40"
               HorizontalTextAlignment="End"
               TextColor="White"
               BackgroundColor="Black"
               IsReadOnly="True" />

        <!-- Buttons Grid -->
        <Grid RowSpacing="10" ColumnSpacing="10">

            <!-- Row Definitions -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Column Definitions -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Row 0 -->
            <Button Text="C" Grid.Row="0" Grid.Column="0" Clicked="OnClear"/>
            <Button Text="⌫" Grid.Row="0" Grid.Column="1" Clicked="OnDelete"/>
            <Button Text="/" Grid.Row="0" Grid.Column="2" Clicked="OnOperator"/>
            <Button Text="*" Grid.Row="0" Grid.Column="3" Clicked="OnOperator"/>

            <!-- Row 1 -->
            <Button Text="7" Grid.Row="1" Grid.Column="0" Clicked="OnNumber"/>
            <Button Text="8" Grid.Row="1" Grid.Column="1" Clicked="OnNumber"/>
            <Button Text="9" Grid.Row="1" Grid.Column="2" Clicked="OnNumber"/>
            <Button Text="-" Grid.Row="1" Grid.Column="3" Clicked="OnOperator"/>

            <!-- Row 2 -->
            <Button Text="4" Grid.Row="2" Grid.Column="0" Clicked="OnNumber"/>
            <Button Text="5" Grid.Row="2" Grid.Column="1" Clicked="OnNumber"/>
            <Button Text="6" Grid.Row="2" Grid.Column="2" Clicked="OnNumber"/>
            <Button Text="+" Grid.Row="2" Grid.Column="3" Clicked="OnOperator"/>

            <!-- Row 3 -->
            <Button Text="1" Grid.Row="3" Grid.Column="0" Clicked="OnNumber"/>
            <Button Text="2" Grid.Row="3" Grid.Column="1" Clicked="OnNumber"/>
            <Button Text="3" Grid.Row="3" Grid.Column="2" Clicked="OnNumber"/>
            <Button Text="=" Grid.Row="3" Grid.Column="3" Grid.RowSpan="2" Clicked="OnEquals"/>

            <!-- Row 4 -->
            <Button Text="0" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Clicked="OnNumber"/>
            <Button Text="." Grid.Row="4" Grid.Column="2" Clicked="OnDecimal"/>

        </Grid>

    </VerticalStackLayout>

</ContentPage>
